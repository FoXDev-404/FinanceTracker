# Django settings
# Generate a new secret key at: https://djecrety.ir/
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-railway-backend-domain.up.railway.app

# Database — Railway sets this automatically when you add a PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenAI API (required for AI features)
OPENAI_API_KEY=your-openai-api-key-here

# CORS — comma-separated list of your frontend URLs
# Add your Vercel URL here after deploying the frontend
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Email settings (optional — for password reset emails)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
